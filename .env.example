# ── Agent Zero Core ──────────────────────────────────────────────────────────
AGENT_ZERO_API_URL=http://agent-zero:5000
AGENT_ZERO_API_KEY=

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:changeme@postgres:5432/agentzero
POSTGRES_PASSWORD=changeme

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Dashboard ─────────────────────────────────────────────────────────────────
PORT=4001
NODE_ENV=production

# ── Telegram (optional) ───────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_WEBHOOK_URL=https://your-domain.com/api/telegram/webhook

# ── Observability ─────────────────────────────────────────────────────────────
LOG_LEVEL=info
ENVIRONMENT=production
